# Copy this file to .env (which is gitignored) and fill in real values:
#   cp .env.example .env
# The example scripts auto-load this file via gst_webrtc.load_env().
# (Shell/benchmark scripts load it via:  set -a; source .env; set +a)

# --- LiOS image transport (sender + receiver) ---
ROOM=demo
SIGNAL_URL=ws://127.0.0.1:18080/ws
STUN=stun://stun.l.google.com:19302
# TURN / coturn relay, used by the gst sender + receiver.
TURN=turn://USERNAME:PASSWORD@TURN_HOST:3478?transport=udp

# Sender video source. Default "test" needs no real camera. Switch to "v4l2"
# to use real cameras.
VIDEO_SOURCE=test
# test mode: comma-separated stream names (optionally name@fps)
#   CAMERAS=cam0,cam1
# v4l2 mode: name=/dev/videoN@fps, comma-separated
#   CAMERAS=mid=/dev/video0@30,left=/dev/video4@25
CAMERAS=cam0,cam1

# Capture resolution + default framerate (per-camera @fps in CAMERAS overrides FPS).
WIDTH=640
HEIGHT=480
FPS=30

# Codec selection. "auto" picks the GPU path (NVENC/NVDEC) when available, else
# CPU (x264 / avdec_h264). Force CPU on a box without a usable GPU with "sw".
#   ENCODER (sender):  auto | nv | sw
#   DECODER (receiver): auto | nv | sw
ENCODER=auto
DECODER=auto

# --- LiveKit comparison benchmarks (OPTIONAL; not needed to run LiOS) ---
# Only consumed by the LiveKit benchmark scripts under benchmark/livekit/
# (run_lat.sh / relat_repeat.sh, etc.). Leave blank unless you run them.
LK_URL=wss://YOUR-PROJECT.livekit.cloud
LK_KEY=
LK_SECRET=
