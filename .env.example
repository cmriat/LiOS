# Copy this file to .env (which is gitignored) and fill in real values:
#   cp .env.example .env
# The example scripts auto-load this file via gst_webrtc.load_env().
# (Shell/benchmark scripts load it via:  set -a; source .env; set +a)

# --- LiOS image transport (sender + receiver) ---
ROOM=demo
SIGNAL_URL=ws://127.0.0.1:18080/ws
STUN=stun://stun.l.google.com:19302
# TURN is set in the coturn section below.

# Sender video source. Default "test" runs with no real camera (GPU still
# required for NVENC). Switch to "v4l2" to use real cameras.
VIDEO_SOURCE=test
# test mode: comma-separated stream names (optionally name@fps)
#   CAMERAS=cam0,cam1
# v4l2 mode: name=/dev/videoN@fps, comma-separated
#   CAMERAS=mid=/dev/video0@30,left=/dev/video4@25
CAMERAS=cam0,cam1

# --- LiveKit Cloud credentials ---
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Aliases consumed by benchmark scripts (run_lat.sh / relat_repeat.sh expect LK_*)
LK_URL=wss://YOUR-PROJECT.livekit.cloud
LK_KEY=
LK_SECRET=

# --- TURN / coturn credentials ---
# Used by the gst sender/receiver (TURN) and by the LiveKit latency scripts
# (LK_TURN_USER / LK_TURN_PASS, only when LK_TURN is set).
TURN=turn://USERNAME:PASSWORD@TURN_HOST:3478?transport=udp
LK_TURN_USER=
LK_TURN_PASS=
